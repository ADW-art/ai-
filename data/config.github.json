  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 16384,
    "throttle_sec": 0.5,
    "analysis_concurrency": 3,
    "enrichment_concurrency": 4,
    "languages": [
      "zh"
    ]
  },
