{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "base_url": "https://api.deepseek.com",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "throttle_sec": 0.5,
    "analysis_concurrency": 5,
    "enrichment_concurrency": 3
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 80
    },
    "rss": [
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "The Hacker News",
        "url": "https://feeds.feedburner.com/TheHackersNews",
        "enabled": true,
        "category": "security"
      },
      {
        "name": "Krebs on Security",
        "url": "https://krebsonsecurity.com/feed/",
        "enabled": true,
        "category": "security"
      },
      {
        "name": "BleepingComputer",
        "url": "https://www.bleepingcomputer.com/feed/",
        "enabled": true,
        "category": "security"
      },
      {
        "name": "PortSwigger Research",
        "url": "https://portswigger.net/research/rss",
        "enabled": true,
        "category": "security"
      },
      {
        "name": "GitHub Trending Daily",
        "url": "https://mshibanami.github.io/GitHubTrendingRSS/daily/all.xml",
        "enabled": true,
        "category": "tech"
      },
      {
        "name": "The Verge - AI",
        "url": "https://www.theverge.com/ai-artificial-intelligence/rss/index.xml",
        "enabled": true,
        "category": "ai"
      },
      {
        "name": "InfoQ - AI/ML",
        "url": "https://feed.infoq.com/artificial-intelligence",
        "enabled": true,
        "category": "ai"
      }
    ],
    "reddit": {
      "enabled": true,
      "subreddits": [
        {
          "subreddit": "netsec",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        },
        {
          "subreddit": "cybersecurity",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        },
        {
          "subreddit": "redteamsec",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 5
        },
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 30
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 20
        },
        {
          "subreddit": "programming",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 10,
          "min_score": 100
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "github": [
      {
        "type": "user_events",
        "username": "karpathy",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true,
        "category": "ai"
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langgraph",
        "enabled": true,
        "category": "ai"
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "autogen",
        "enabled": true,
        "category": "ai"
      },
      {
        "type": "repo_releases",
        "owner": "crewAIInc",
        "repo": "crewAI",
        "enabled": true,
        "category": "ai"
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true,
        "category": "ai"
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      }
    ]
  },
  "filtering": {
    "ai_score_threshold": 6.0,
    "time_window_hours": 24,
    "max_items": 20,
    "category_groups": {
      "security": {
        "limit": 7,
        "categories": [
          "security"
        ]
      },
      "ai": {
        "limit": 7,
        "categories": [
          "ai"
        ]
      },
      "tech": {
        "limit": 6,
        "categories": [
          "tech"
        ]
      }
    },
    "default_group": "other",
    "default_group_limit": 3
  },
  "webhook": {
    "enabled": true,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary_and_items",
    "overview_position": "last",
    "platform": "feishu",
    "layout": "collapsible",
    "fallback_layout": "markdown",
    "languages": [
      "zh"
    ],
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}